# ---------------------------------------------------------------------------
# LaunchPad — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Local Postgres example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/launchpad?schema=public"
# Supabase: use the "Connection string" from Project Settings > Database
# (transaction pooler for serverless, session pooler for long-lived servers):
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# NextAuth secret — sign/encrypt session JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"

# Canonical URL of the app (used by NextAuth for callbacks).
NEXTAUTH_URL="http://localhost:3000"

# Optional: password used for the demo accounts created by `npm run db:seed`.
# Dev only. Defaults to "changeme123" if unset.
# SEED_USER_PASSWORD="changeme123"
