// Prisma schema for the community launch platform MVP.
// PostgreSQL. Run `npm run db:migrate` to create the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String    @map("password_hash")
  avatarUrl         String?   @map("avatar_url")
  bio               String?
  role              UserRole  @default(USER)
  emailVerified     DateTime? @map("email_verified")
  createdAt         DateTime  @default(now()) @map("created_at")
  /// Cuenta suspendida por un admin: no puede iniciar sesión ni ejecutar acciones.
  suspendedAt       DateTime? @map("suspended_at")
  /// @handle único. Nullable a nivel de BD (Postgres permite múltiples NULL
  /// bajo UNIQUE) — la app siempre asigna uno al registrarse; el backfill
  /// llena a los usuarios existentes (ver prisma/backfill-usernames.ts).
  username          String?   @unique
  /// Se puede editar una sola vez: NULL = todavía no lo cambió manualmente.
  usernameChangedAt DateTime? @map("username_changed_at")

  products                Product[]
  upvotes                 Upvote[]
  comments                Comment[]
  reportsFiled            ModerationReport[]       @relation("ReportsFiled")
  reportsResolved         ModerationReport[]       @relation("ReportsResolved")
  communityLinks          CommunityLink[]
  extensionEvents         ExtensionEvent[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notificationsReceived   Notification[]           @relation("NotificationsReceived")
  notificationsActed      Notification[]           @relation("NotificationsActed")
  uploadedImages          UploadedImage[]
  contactRequestsSent     ContactRequest[]
  badges                  UserBadge[]
  badgesGranted           UserBadge[]              @relation("BadgesGranted")

  @@map("users")
}

// User-uploaded images (product logos, avatars). Stored as bytea for MVP —
// small files (≤2MB), zero external services, portable to any Postgres host.
// Swapping to object storage later only changes the /api/uploads internals;
// the public `/api/uploads/:id` URLs stay stable.
model UploadedImage {
  id         String   @id @default(cuid())
  uploaderId String   @map("uploader_id")
  mime       String
  size       Int
  data       Bytes
  createdAt  DateTime @default(now()) @map("created_at")

  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("uploaded_images")
}

// ---------------------------------------------------------------------------
// Products & categories
// ---------------------------------------------------------------------------

enum ProductStatus {
  DRAFT
  SCHEDULED
  LIVE
  ARCHIVED
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  makerId     String        @map("maker_id")
  name        String
  slug        String        @unique
  tagline     String
  description String
  websiteUrl  String?       @map("website_url")
  logoUrl     String?       @map("logo_url")
  categoryId  String        @map("category_id")
  launchDate  DateTime      @map("launch_date")
  status      ProductStatus @default(DRAFT)

  // --- Puente de compraventa (Fase 2): métricas declaradas + interés ---
  openToOffers     Boolean   @default(false) @map("open_to_offers")
  declaredMrrUsd   Int?      @map("declared_mrr_usd") // USD/mes, declarado por el maker, NO verificado
  monetizationNote String?   @map("monetization_note")
  // Señal del puente: vistas de la oferta (sin deduplicar) y candado del email de tracción.
  offerViewCount   Int       @default(0) @map("offer_view_count")
  offerNudgeSentAt DateTime? @map("offer_nudge_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  maker           User               @relation(fields: [makerId], references: [id], onDelete: Cascade)
  category        Category           @relation(fields: [categoryId], references: [id])
  upvotes         Upvote[]
  comments        Comment[]
  reports         ModerationReport[]
  notifications   Notification[]
  images          ProductImage[]
  contactRequests ContactRequest[]
  updates         ProductUpdate[]

  @@index([status, launchDate])
  @@index([makerId])
  @@index([categoryId])
  @@map("products")
}

/// Bitácora de progreso: updates cortos que el maker publica en su propio
/// producto (avances, novedades). Público, solo lectura para todos.
model ProductUpdate {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@map("product_updates")
}

/// Product gallery screenshots (URLs — typically /api/uploads/:id).
/// Capped at 5 per product in the API layer.
model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  sort      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sort])
  @@map("product_images")
}

/// Solicitud de contacto de un comprador interesado en un producto
/// "abierto a ofertas". El maker decide compartir su email (SHARED) o
/// descartar (DISMISSED). Sin mensajería interna: el contacto sigue por email.
enum ContactRequestStatus {
  PENDING
  SHARED
  DISMISSED
}

model ContactRequest {
  id        String               @id @default(cuid())
  productId String               @map("product_id")
  buyerId   String               @map("buyer_id")
  message   String
  status    ContactRequestStatus @default(PENDING)
  createdAt DateTime             @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // Un comprador solo puede solicitar contacto una vez por producto (anti-spam).
  @@unique([productId, buyerId])
  @@index([productId, status])
  @@map("contact_requests")
}

// ---------------------------------------------------------------------------
// Engagement
// ---------------------------------------------------------------------------

model Upvote {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // One upvote per user per product, enforced at the database level.
  @@unique([userId, productId])
  @@index([productId])
  @@map("upvotes")
}

model Comment {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  productId String    @map("product_id")
  body      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete for moderation trail

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  reports       ModerationReport[]
  notifications Notification[]

  @@index([productId, createdAt])
  @@map("comments")
}

// ---------------------------------------------------------------------------
// Moderation
// ---------------------------------------------------------------------------

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model ModerationReport {
  id           String       @id @default(cuid())
  /// NULL = reporte auto-generado por el sistema (detección de contenido sospechoso), no por un usuario.
  reporterId   String?      @map("reporter_id")
  productId    String?      @map("product_id")
  commentId    String?      @map("comment_id")
  reason       String
  status       ReportStatus @default(OPEN)
  resolvedById String?      @map("resolved_by_id")
  resolvedAt   DateTime?    @map("resolved_at") // audit: when it was resolved/dismissed
  createdAt    DateTime     @default(now()) @map("created_at")

  reporter   User?    @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("ReportsResolved", fields: [resolvedById], references: [id])
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("moderation_reports")
}

// ---------------------------------------------------------------------------
// Browser-extension support (consent-based, manual submissions only)
// ---------------------------------------------------------------------------
// These tables only store links a user *explicitly chose* to submit.
// There is no automation: no auto-upvoting, no scraping, no credential
// storage. The extension calls the same authenticated APIs a human would.

enum LinkStatus {
  PENDING
  VERIFIED
  REJECTED
}

model CommunityLink {
  id             String     @id @default(cuid())
  submittedById  String     @map("submitted_by")
  title          String
  url            String
  sourcePlatform String     @map("source_platform") // e.g. "skool"
  type           String // e.g. "logro", "milestone", "announcement"
  status         LinkStatus @default(PENDING)
  createdAt      DateTime   @default(now()) @map("created_at")

  submittedBy User @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  // The same user cannot submit the same URL twice.
  @@unique([submittedById, url])
  @@index([status])
  @@map("community_links")
}

model ExtensionEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type") // e.g. "link_submitted", "link_viewed"
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("extension_events")
}

// ---------------------------------------------------------------------------
// Auth tokens (password reset & email verification)
// ---------------------------------------------------------------------------
// Only the sha256 hash of each token is stored. Tokens expire (1h) and are
// single-use (usedAt). The plaintext token only ever travels in the email link.

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// In-app notifications
// ---------------------------------------------------------------------------
// Created when someone upvotes or comments on your product (never for your
// own actions). Consumed by the frontend "bell". No emails, no push — MVP.

enum NotificationType {
  UPVOTE
  COMMENT
  MENTION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id") // recipient
  actorId   String           @map("actor_id") // who triggered it
  type      NotificationType
  productId String?          @map("product_id")
  commentId String?          @map("comment_id")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user    User     @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor   User     @relation("NotificationsActed", fields: [actorId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ---------------------------------------------------------------------------
// Insignias
// ---------------------------------------------------------------------------

/// Catálogo fijo de insignias. Agregar una nueva es una fila (seed), no
/// requiere código nuevo salvo que también necesite un trigger automático.
model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  createdAt   DateTime @default(now()) @map("created_at")

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  badgeId     String   @map("badge_id")
  /// NULL = otorgada automáticamente por el sistema. No-NULL = admin que la otorgó a mano.
  grantedById String?  @map("granted_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("BadgesGranted", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}
